{
    "name": "planet-oxy",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "dev": "vite dev --port 8008",
        "launch": "vite dev --port 8008 --open",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "eslint .",
        "init:houdini": "bunx houdini@next init",
        "generate:houdini": "bunx houdini generate",
        "pull:houdini": "bunx houdini pull-schema"
    },
    "devDependencies": {
        "@sveltejs/adapter-node": "^5.5.7",
        "@sveltejs/kit": "^2.70.0",
        "@sveltejs/vite-plugin-svelte": "^7.2.0",
        "@types/bun": "^1.3.14",
        "@types/eslint": "^9.6.1",
        "autoprefixer": "^10.5.4",
        "eslint": "^10.7.0",
        "eslint-plugin-svelte": "^3.20.0",
        "globals": "^17.7.0",
        "houdini": "^2.0.8",
        "houdini-svelte": "^3.0.4",
        "mdsvex": "^0.12.7",
        "prettier": "^3.9.5",
        "prettier-plugin-svelte": "^4.1.1",
        "prettier-plugin-tailwindcss": "^0.8.1",
        "svelte": "^5.56.6",
        "svelte-check": "^4.7.3",
        "tailwindcss": "^4.3.3",
        "tslib": "^2.8.1",
        "typescript": "^7.0.2",
        "typescript-eslint": "^8.64.0",
        "vite": "^8.1.5"
    },
    "type": "module",
    "dependencies": {
        "@sanity/client": "^7.23.2",
        "@tailwindcss/vite": "^4.3.3",
        "gray-matter": "^4.0.3",
        "highlight.js": "^11.11.1",
        "marked": "^18.0.6",
        "marked-highlight": "^2.2.4"
    }
