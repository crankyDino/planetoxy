{
    "name": "planet-oxy",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "dev": "vite dev --port 8008",
        "launch": "vite dev --port 8008 --open",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "eslint .",
        "init:houdini": "bunx houdini@next init",
        "generate:houdini": "bunx houdini generate",
        "pull:houdini": "bunx houdini pull-schema"
    },
    "devDependencies": {
        "@sveltejs/adapter-node": "^5.2.11",
        "@sveltejs/kit": "^2.57.1",
        "@sveltejs/vite-plugin-svelte": "^4.0.4",
        "@types/eslint": "^8.56.12",
        "autoprefixer": "^10.4.27",
        "eslint": "^9.39.4",
        "eslint-plugin-svelte": "^2.46.1",
        "globals": "^15.15.0",
        "houdini": "^2.0.0-next.11",
        "houdini-svelte": "^3.0.0-next.13",
        "mdsvex": "^0.12.7",
        "prettier": "^3.8.2",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "svelte": "^5.55.3",
        "svelte-check": "^4.4.6",
        "tailwindcss": "^4.2.2",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.58.1",
        "vite": "^5.4.21",
        "@types/bun": "latest"
    },
    "type": "module",
    "dependencies": {
        "@sanity/client": "^6.29.1",
        "@tailwindcss/vite": "^4.2.2",
        "gray-matter": "^4.0.3",
        "highlight.js": "^11.11.1",
        "marked": "^17.0.6",
        "marked-highlight": "^2.2.4"
    }
